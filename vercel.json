{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "headers": [
    {"source":"/assets/(.*)","headers":[{"key":"Cache-Control","value":"public, max-age=31536000, immutable"}]},
    {"source":"/(.*\\.png|.*\\.otf|.*\\.ico)","headers":[{"key":"Cache-Control","value":"public, max-age=31536000, immutable"}]}
  ],
  "rewrites": [
    {"source":"/((?!assets|.*\\.png|.*\\.ico|.*\\.otf|.*\\.js|.*\\.css).*)","destination":"/index.html"}
  ]
}
